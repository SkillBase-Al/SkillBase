---
import '../styles/global.css';
import { getLocale, useTranslations } from '../i18n';

export interface Props {
  title?: string;
  description?: string;
  locale?: 'zh' | 'en';
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const loc = Astro.props.locale ?? getLocale(Astro.url);
const { t } = useTranslations(loc);

const siteTitle = title ?? t('site.title');
const siteDesc = description ?? t('site.description');
const siteUrl = 'https://skillbase.app';
const canonicalUrl = canonical ?? (loc === 'en' ? `${siteUrl}/en/` : `${siteUrl}/`);
const enUrl = `${siteUrl}/en/`;
const zhUrl = `${siteUrl}/`;
const ogImage = `${siteUrl}/og-image.png`;
---

<!doctype html>
<html lang={loc === 'en' ? 'en' : 'zh-CN'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDesc} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="zh" href={zhUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={zhUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDesc} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDesc} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "SkillBase",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "macOS, Windows, Linux",
      "description": siteDesc,
      "url": canonicalUrl,
      "version": "0.1.4",
      "license": "https://github.com/SkillBase-Al/SkillBase/blob/main/LICENSE",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <slot name="head" />
  </head>
  <body>
    <slot />

    <script>
      // Fetch latest release info from API and update dynamic elements
      (async function() {
        try {
          const res = await fetch('/api/v1/downloads');
          const data = await res.json();
          const version = data.version;

          // Update version badge in Hero section
          const badge = document.getElementById('version-badge');
          if (badge) {
            badge.textContent = `v${version} — Open Source`;
          }

          // Update version badges
          document.querySelectorAll('[data-version]').forEach(el => {
            el.textContent = `v${version}`;
          });

          // Update structured data version
          document.querySelectorAll('script[type="application/ld+json"]').forEach(el => {
            try {
              const json = JSON.parse(el.textContent || '{}');
              if (json.version) {
                json.version = version;
                el.textContent = JSON.stringify(json);
              }
            } catch {}
          });

          // Update download links with real GitHub release URLs
          if (data.downloads && data.downloads.length > 0) {
            // Map platform ID to attribute lookup
            var platformMap = {};
            data.downloads.forEach(function(d) { platformMap[d.platform] = d; });

            // Update each download link card
            document.querySelectorAll('[data-platform]').forEach(function(card) {
              var platform = card.getAttribute('data-platform');
              var link = card.querySelector('[data-download-link]');
              // Platform IDs from Download.astro: macos, windows, linux
              // APIs return macos, windows-exe, windows-msi, linux-appimage, linux-deb
              var download = platformMap[platform] || platformMap[platform + '-exe'] || platformMap[platform + '-appimage'] || platformMap[platform + '-deb'];
              if (download && link) {
                link.setAttribute('href', download.url);
              }
            });
          }
        } catch (e) {
          // Fallback: try version-only endpoint
          try {
            var r2 = await fetch('/api/v1/version');
            var d2 = await r2.json();
            var ver = d2.version;
            var badgeEl = document.getElementById('version-badge');
            if (badgeEl) badgeEl.textContent = 'v' + ver + ' — Open Source';
            document.querySelectorAll('[data-version]').forEach(function(el) { el.textContent = 'v' + ver; });
            document.querySelectorAll('[data-version-url]').forEach(function(el) {
              var tpl = el.getAttribute('data-version-url');
              if (tpl) el.setAttribute('href', tpl.replace(/\{version\}/g, ver));
            });
          } catch(e2) {
            console.warn('Failed to fetch version info, using fallback', e2);
          }
        }
      })();
    </script>
  </body>
</html>
