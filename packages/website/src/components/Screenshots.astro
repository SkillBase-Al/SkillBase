---
export interface Props {
  locale: 'zh' | 'en';
  t: (path: string) => string;
}

const { locale, t } = Astro.props;
---

<section id="screenshots" class="section-padding bg-white">
  <div class="section-container">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{t('screenshots.title')}</h2>
      <p class="mt-3 text-lg text-slate-500">{t('screenshots.subtitle')}</p>
    </div>

    <!-- Screenshot grid -->
    <div class="grid sm:grid-cols-2 gap-6">
      <div class="rounded-2xl overflow-hidden border border-slate-200 shadow-sm">
        <img src="/screenshot-1.png" alt="SkillBase Discover" class="w-full h-auto" loading="lazy" />
      </div>
      <div class="rounded-2xl overflow-hidden border border-slate-200 shadow-sm">
        <img src="/screenshot-2.png" alt="SkillBase Detail" class="w-full h-auto" loading="lazy" />
      </div>
    </div>
  </div>
</section>
