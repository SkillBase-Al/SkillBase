---
export interface Props {
  locale: 'zh' | 'en';
  t: (path: string) => string;
}

const { locale, t } = Astro.props;
---

<section id="screenshots" class="section-padding bg-white">
  <div class="section-container">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{t('screenshots.title')}</h2>
      <p class="mt-3 text-lg text-slate-500">{t('screenshots.subtitle')}</p>
    </div>

    <!-- Screenshot placeholder grid -->
    <div class="grid sm:grid-cols-2 gap-6">
      <div class="aspect-video rounded-2xl border-2 border-dashed border-slate-200 bg-slate-50 flex items-center justify-center">
        <div class="text-center">
          <svg class="h-10 w-10 text-slate-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <p class="text-sm text-slate-400">{locale === 'zh' ? '应用截图（待添加）' : 'Screenshots (coming soon)'}</p>
        </div>
      </div>
      <div class="aspect-video rounded-2xl border-2 border-dashed border-slate-200 bg-slate-50 flex items-center justify-center">
        <div class="text-center">
          <svg class="h-10 w-10 text-slate-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <p class="text-sm text-slate-400">{locale === 'zh' ? '应用截图（待添加）' : 'Screenshots (coming soon)'}</p>
        </div>
      </div>
    </div>
    <p class="text-center text-xs text-slate-400 mt-4">
      {locale === 'zh' ? '* 截图 placeholder，等你提供应用截图后替换' : '* Placeholder screenshots — replace with your actual app screenshots'}
    </p>
  </div>
</section>
