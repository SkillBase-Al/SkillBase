---
export interface Props {
  locale: 'zh' | 'en';
  t: (path: string) => string;
}

const { locale, t } = Astro.props;

const agents = [
  { key: 'claude', color: 'bg-orange-50 text-orange-600', label: 'Claude' },
  { key: 'cursor', color: 'bg-green-50 text-green-600', label: 'Cursor' },
  { key: 'codex', color: 'bg-blue-50 text-blue-600', label: 'Codex' },
  { key: 'opencode', color: 'bg-purple-50 text-purple-600', label: 'OpenCode' },
  { key: 'windsurf', color: 'bg-cyan-50 text-cyan-600', label: 'Windsurf' },
  { key: 'qoder', color: 'bg-rose-50 text-rose-600', label: 'Qoder' },
];
---

<section id="agents" class="section-padding bg-slate-50">
  <div class="section-container">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{t('agents.title')}</h2>
      <p class="mt-3 text-lg text-slate-500">{t('agents.subtitle')}</p>
      <p class="mt-2 text-base text-brand-600 font-medium">{t('agents.customNote')}</p>
    </div>

    <!-- Agent cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {agents.map((agent) => (
        <div class="flex items-start gap-4 rounded-xl border border-slate-200 bg-white p-5 hover:border-slate-300 transition-colors">
          <div class={`flex items-center justify-center h-10 w-10 rounded-xl font-bold text-sm flex-shrink-0 ${agent.color}`}>
            {agent.label.slice(0, 2)}
          </div>
          <div>
            <h3 class="text-sm font-semibold text-slate-900">{t(`agents.agents.${agent.key}.name`)}</h3>
            <p class="text-xs text-slate-500 mt-1 leading-relaxed">{t(`agents.agents.${agent.key}.desc`)}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
