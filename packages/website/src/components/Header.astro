---
export interface Props {
  locale: 'zh' | 'en';
  t: (path: string) => string;
}

const { locale, t } = Astro.props;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
  <div class="section-container flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5">
      <div class="flex items-center justify-center h-8 w-8 rounded-lg bg-brand-600 text-white text-sm font-bold">
        S
      </div>
      <span class="text-lg font-bold text-slate-900">SkillBase</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="#features" class="text-sm text-slate-600 hover:text-brand-600 transition-colors">{t('nav.features')}</a>
      <a href="#agents" class="text-sm text-slate-600 hover:text-brand-600 transition-colors">{t('nav.agents')}</a>
      <a href="#screenshots" class="text-sm text-slate-600 hover:text-brand-600 transition-colors">{t('nav.screenshots')}</a>
      <a href="#download" class="text-sm text-slate-600 hover:text-brand-600 transition-colors">{t('nav.download')}</a>
      <a href="#faq" class="text-sm text-slate-600 hover:text-brand-600 transition-colors">{t('nav.faq')}</a>
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-3">
      <!-- GitHub Star -->
      <a
        href="https://github.com/SkillBase-Al/SkillBase"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:flex items-center gap-1.5 text-xs text-slate-500 hover:text-slate-700 transition-colors"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        <span>Star</span>
      </a>

      <!-- Language switch -->
      <a
        href={t('nav.languageHref')}
        class="text-xs font-medium text-slate-500 hover:text-brand-600 transition-colors px-2 py-1 rounded-md border border-slate-200 hover:border-brand-300"
      >
        {t('nav.language')}
      </a>

      <!-- Mobile menu button -->
      <button class="md:hidden p-2 text-slate-600 hover:text-slate-900" id="menu-btn">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <nav id="mobile-menu" class="md:hidden hidden border-t border-slate-100 bg-white px-4 py-4 space-y-3">
    <a href="#features" class="block text-sm text-slate-600 hover:text-brand-600">{t('nav.features')}</a>
    <a href="#agents" class="block text-sm text-slate-600 hover:text-brand-600">{t('nav.agents')}</a>
    <a href="#screenshots" class="block text-sm text-slate-600 hover:text-brand-600">{t('nav.screenshots')}</a>
    <a href="#download" class="block text-sm text-slate-600 hover:text-brand-600">{t('nav.download')}</a>
    <a href="#faq" class="block text-sm text-slate-600 hover:text-brand-600">{t('nav.faq')}</a>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
