---
export interface Props {
  locale: 'zh' | 'en';
  t: (path: string) => string;
}

const { t } = Astro.props;

const features = [
  { icon: 'install', iconSvg: 'M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4' },
  { icon: 'scan', iconSvg: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z' },
  { icon: 'security', iconSvg: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
  { icon: 'sync', iconSvg: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15' },
];
---

<section id="features" class="section-padding bg-white">
  <div class="section-container">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{t('features.title')}</h2>
      <p class="mt-3 text-lg text-slate-500">{t('features.subtitle')}</p>
    </div>

    <!-- Feature cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((f) => (
        <div class="group relative rounded-2xl border border-slate-100 bg-white p-6 hover:border-brand-100 hover:shadow-lg hover:shadow-brand-50 transition-all duration-300">
          <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-brand-50 text-brand-600 group-hover:bg-brand-100 transition-colors mb-4">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={f.iconSvg} />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">{t(`features.${f.icon}.title`)}</h3>
          <p class="text-sm text-slate-500 leading-relaxed">{t(`features.${f.icon}.desc`)}</p>
        </div>
      ))}
    </div>
  </div>
</section>
